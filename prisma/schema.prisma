datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("VIEWER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedBars       Bar[]
  createdMovements  StockMovement[] @relation("CreatedBy")
  approvedMovements StockMovement[] @relation("ApprovedBy")
  auditLogs         AuditLog[]
}

model Event {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime
  venue     String
  status    String   @default("SETUP")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bars         Bar[]
  products     EventProduct[]
  centralStock EventCentralStock[]
}

model Bar {
  id                 Int      @id @default(autoincrement())
  eventId            Int
  name               String
  location           String?
  responsibleCompany String?
  status             String   @default("OPEN")
  stockType          String   @default("PAID")
  barType            String   @default("BAR")
  managerId          Int?
  accessToken        String   @unique @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  event             Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  manager           User?          @relation(fields: [managerId], references: [id])
  inventory         BarInventory[]
  outboundMovements StockMovement[] @relation("FromBar")
  inboundMovements  StockMovement[] @relation("ToBar")
  confirmations     BarStockConfirmation[]
  closingCounts     BarClosingCount[]

  @@unique([eventId, name])
}

model BarStockConfirmation {
  id                Int      @id @default(autoincrement())
  barId             Int
  productId         Int
  confirmedQuantity Int
  confirmedTots     Int      @default(0)
  confirmedBy       String?
  notes             String?
  confirmedAt       DateTime @default(now())

  bar     Bar     @relation(fields: [barId],     references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([barId, productId])
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  unit          String
  category      String?
  totsPerBottle Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  eventProducts EventProduct[]
  inventory     BarInventory[]
  movementLines MovementLine[]
  centralStock  EventCentralStock[]
  confirmations BarStockConfirmation[]
  closingCounts BarClosingCount[]
}

model EventProduct {
  id        Int     @id @default(autoincrement())
  eventId   Int
  productId Int
  isActive  Boolean @default(true)

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([eventId, productId])
}

model StockMovement {
  id           Int      @id @default(autoincrement())
  eventId      Int
  type         String
  status       String   @default("PENDING")
  fromBarId    Int?
  toBarId      Int?
  createdById  Int
  approvedById Int?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  approvedAt   DateTime?
  dispatchedAt DateTime?
  deliveredAt  DateTime?

  fromBar    Bar?  @relation("FromBar", fields: [fromBarId], references: [id])
  toBar      Bar?  @relation("ToBar",   fields: [toBarId],   references: [id])
  createdBy  User  @relation("CreatedBy",  fields: [createdById],  references: [id])
  approvedBy User? @relation("ApprovedBy", fields: [approvedById], references: [id])

  lines MovementLine[]
}

model MovementLine {
  id                Int  @id @default(autoincrement())
  movementId        Int
  productId         Int
  quantityRequested Int
  quantityActual    Int?
  totsRequested     Int?
  totsActual        Int?

  movement StockMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId],  references: [id])
}

model BarInventory {
  id              Int      @id @default(autoincrement())
  barId           Int
  productId       Int
  openingQuantity Int      @default(0)
  currentQuantity Int      @default(0)
  openingTots     Int      @default(0)
  currentTots     Int      @default(0)
  updatedAt       DateTime @updatedAt

  bar     Bar     @relation(fields: [barId],     references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([barId, productId])
}

model EventCentralStock {
  id        Int      @id @default(autoincrement())
  eventId   Int
  productId Int
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([eventId, productId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String   // e.g. "event.status_changed", "movement.approved"
  entityType String   // e.g. "Event", "StockMovement"
  entityId   Int
  detail     String?  // JSON string with before/after or context
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model BarClosingCount {
  id              Int      @id @default(autoincrement())
  barId           Int
  productId       Int
  closingQuantity Int      @default(0)
  closingTots     Int      @default(0)
  countedBy       String?
  notes           String?
  submittedAt     DateTime @default(now())

  bar     Bar     @relation(fields: [barId],     references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([barId, productId])
}
